# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=world_cup_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
AIRFLOW_POSTGRES_DB=airflow_db
DATABASE_URL=postgresql://postgres:your_password_here@db:5432/world_cup_db
AIRFLOW_DATABASE_URL=postgresql+psycopg2://postgres:your_password_here@db:5432/airflow_db

# Airflow Configuration
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_WEBSERVER_SECRET_KEY=change_me_for_local_dev
AIRFLOW_IMAGE=apache/airflow:latest-python3.12
AIRFLOW_LOAD_EXAMPLES=False

# API Key from wc2026api.com
WC2026_API_KEY="[API KEY]"

# RabbitMQ Configuration
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
PLAYER_STATS_UPDATES_QUEUE=player_stats_updates

# Proxy Configuration (for bypassing 403 blocks)
PROXY_SERVER=http://your-proxy-server:port
PROXY_USER=username
PROXY_PASSWORD=password

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
